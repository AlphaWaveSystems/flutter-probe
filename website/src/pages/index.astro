---
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FlutterProbe — Flutter E2E Tests in Plain English</title>
  <meta name="description" content="High-performance local E2E testing framework for Flutter mobile apps. Natural language syntax with sub-50ms execution via direct widget-tree access." />
  <meta name="keywords" content="flutter, e2e testing, integration testing, mobile testing, ProbeScript, natural language tests" />
  <meta property="og:title" content="FlutterProbe — Flutter E2E Tests in Plain English" />
  <meta property="og:description" content="Write tests your whole team can read. Execute with direct widget-tree access for sub-50ms command round-trips." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://alphawavesystems.github.io/flutter-probe/" />
  <link rel="icon" type="image/svg+xml" href="/flutter-probe/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:inline>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #06080d;
      --bg2: #0c1018;
      --bg3: #121826;
      --border: #1e2940;
      --border2: #2a3a58;
      --text: #d8e0f0;
      --muted: #7889a8;
      --accent: #3bf0e4;
      --green: #3bea7e;
      --purple: #a78bfa;
      --amber: #f5b731;
      --coral: #ff6b6b;
    }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { opacity: 0.85; }
    /* ── Nav ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.25rem 2rem;
      position: relative;
      z-index: 10;
    }
    .nav-logo {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--accent);
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .nav-logo svg { width: 28px; height: 28px; }
    .nav-r { display: flex; gap: 1.5rem; align-items: center; }
    .nav-r a { color: var(--muted); font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
    .nav-r a:hover { color: var(--text); opacity: 1; }
    .btn-sm {
      padding: 0.45rem 1.1rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.85rem;
      background: var(--accent);
      color: #06080d;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-sm:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(59, 240, 228, 0.25);
      opacity: 1;
    }
    /* ── Hero ── */
    .hero {
      text-align: center;
      padding: 7rem 2rem 5rem;
      position: relative;
      max-width: 960px;
      margin: 0 auto;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(59, 240, 228, 0.04) 0%, transparent 65%);
      pointer-events: none;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.9rem;
      border: 1px solid var(--border2);
      border-radius: 100px;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 1.5rem;
      background: var(--bg2);
    }
    .badge span {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .hero h1 {
      font-size: clamp(2.4rem, 5.5vw, 4rem);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }
    .hero h1 .g {
      background: linear-gradient(135deg, var(--accent) 0%, #6ee7b7 50%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero .sub {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }
    /* ── Code block ── */
    .hero-code {
      position: relative;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      max-width: 520px;
      margin: 0 auto 2.5rem;
      text-align: left;
      overflow: hidden;
    }
    .hero-code .bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0.6rem 1rem;
      border-bottom: 1px solid var(--border);
      background: var(--bg3);
    }
    .hero-code .dot { width: 10px; height: 10px; border-radius: 50%; border: 1.5px solid var(--border2); }
    .hero-code .fname {
      margin-left: auto;
      font-size: 0.72rem;
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .hero-code pre {
      padding: 1.25rem 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
      line-height: 1.85;
      overflow-x: auto;
    }
    .kw { color: var(--purple); font-weight: 500; }
    .str { color: var(--green); }
    .cmd { color: var(--text); }
    .cmt { color: var(--muted); font-style: italic; }
    /* ── Buttons ── */
    .cta { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-p {
      padding: 0.7rem 1.6rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.95rem;
      background: var(--accent);
      color: #06080d;
      transition: all 0.2s;
      border: none;
      cursor: pointer;
    }
    .btn-p:hover { transform: translateY(-1px); box-shadow: 0 6px 30px rgba(59, 240, 228, 0.3); opacity: 1; }
    .btn-s {
      padding: 0.7rem 1.6rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border2);
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-s:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }
    /* ── Metrics ── */
    .metrics { display: flex; justify-content: center; gap: 3rem; padding: 0 2rem 4rem; flex-wrap: wrap; }
    .metric { text-align: center; }
    .metric .num { font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; }
    .metric .num.t { color: var(--accent); }
    .metric .num.g { color: var(--green); }
    .metric .num.p { color: var(--purple); }
    .metric .num.a { color: var(--amber); }
    .metric .lbl { font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; }
    /* ── Sections ── */
    section { max-width: 1200px; margin: 0 auto; padding: 5rem 2rem; }
    .sec-h { text-align: center; margin-bottom: 3rem; }
    .sec-h h2 { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.6rem; }
    .sec-h p { color: var(--muted); max-width: 520px; margin: 0 auto; font-size: 0.95rem; }
    .divider { width: 100%; max-width: 1200px; margin: 0 auto; height: 1px; background: var(--border); }
    /* ── Architecture ── */
    .arch { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1.5rem; align-items: center; max-width: 800px; margin: 0 auto; }
    .arch-box {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }
    .arch-box h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
    .arch-box p { font-size: 0.8rem; color: var(--muted); }
    .arch-box .tag {
      display: inline-block;
      margin-top: 0.5rem;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }
    .tag-go { background: rgba(59, 240, 228, 0.1); color: var(--accent); }
    .tag-dart { background: rgba(59, 234, 126, 0.1); color: var(--green); }
    .arch-arrow { color: var(--muted); font-size: 1.5rem; text-align: center; }
    .arch-label { font-size: 0.7rem; color: var(--muted); display: block; font-family: 'JetBrains Mono', monospace; }
    /* ── Features ── */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1px;
      background: var(--border);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .feat { background: var(--bg2); padding: 1.75rem; }
    .feat h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.4rem; display: flex; align-items: center; gap: 0.5rem; }
    .feat h3 .ic {
      width: 20px; height: 20px;
      border-radius: 5px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 800;
    }
    .feat p { color: var(--muted); font-size: 0.85rem; line-height: 1.55; }
    .ic-t { background: rgba(59, 240, 228, 0.12); color: var(--accent); }
    .ic-g { background: rgba(59, 234, 126, 0.12); color: var(--green); }
    .ic-p { background: rgba(167, 139, 250, 0.12); color: var(--purple); }
    .ic-a { background: rgba(245, 183, 49, 0.12); color: var(--amber); }
    .ic-c { background: rgba(255, 107, 107, 0.12); color: var(--coral); }
    /* ── Comparison ── */
    .compare {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      max-width: 900px;
      margin: 0 auto;
    }
    .compare-col { background: var(--bg2); }
    .compare-col:first-child { border-right: 1px solid var(--border); }
    .compare-hd {
      padding: 0.75rem 1.25rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .compare-hd span:first-child { font-size: 0.85rem; font-weight: 700; }
    .compare-hd .lines { font-size: 0.72rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
    .compare-code {
      padding: 1.25rem 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      line-height: 1.8;
      white-space: pre;
      overflow-x: auto;
      min-height: 220px;
    }
    /* ── Migration ── */
    .migrate { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; max-width: 700px; margin: 0 auto; }
    .migrate-tag {
      padding: 0.55rem 1.1rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      background: var(--bg2);
      transition: all 0.2s;
      cursor: default;
    }
    .migrate-tag:hover { border-color: var(--accent); color: var(--accent); }
    /* ── Steps ── */
    .steps-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; max-width: 900px; margin: 0 auto; }
    .st {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
    }
    .st .n { font-size: 0.7rem; font-weight: 800; color: var(--accent); margin-bottom: 0.5rem; font-family: 'JetBrains Mono', monospace; }
    .st h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.3rem; }
    .st p { color: var(--muted); font-size: 0.8rem; }
    .st code {
      display: block;
      margin-top: 0.4rem;
      padding: 0.25rem 0.5rem;
      background: var(--bg3);
      border-radius: 4px;
      font-size: 0.72rem;
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent);
      word-break: break-all;
    }
    /* ── Install CTA ── */
    .install { max-width: 600px; margin: 0 auto; text-align: center; }
    .install-box {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
    }
    .install-box .dollar { color: var(--muted); margin-right: 0.5rem; }
    .install-box button {
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--muted);
      padding: 0.3rem 0.7rem;
      border-radius: 5px;
      font-size: 0.75rem;
      cursor: pointer;
      font-family: 'JetBrains Mono', monospace;
      transition: all 0.2s;
    }
    .install-box button:hover { border-color: var(--accent); color: var(--accent); }
    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 0.85rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .foot-links { display: flex; gap: 1.5rem; }
    .foot-links a { color: var(--muted); font-size: 0.85rem; }
    .foot-links a:hover { color: var(--text); }
    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-r a:not(.btn-sm) { display: none; }
      .arch { grid-template-columns: 1fr; gap: 1rem; }
      .arch-arrow { transform: rotate(90deg); }
      .compare { grid-template-columns: 1fr; }
      .steps-row { grid-template-columns: 1fr 1fr; }
      .hero h1 { font-size: 2.2rem; }
    }
    @media (max-width: 480px) {
      .steps-row { grid-template-columns: 1fr; }
      .metrics { gap: 1.5rem; }
    }
  </style>
</head>
<body>
  <!-- Nav -->
  <nav>
    <a href="/flutter-probe/" class="nav-logo">
      <svg viewBox="0 0 28 28" width="28" height="28" fill="none"><rect x="2" y="2" width="24" height="24" rx="6" stroke="#3bf0e4" stroke-width="2"/><path d="M9 14l3 3 7-7" stroke="#3bf0e4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      FlutterProbe
    </a>
    <div class="nav-r">
      <a href="/flutter-probe/getting-started/installation/">Docs</a>
      <a href="/flutter-probe/probescript/syntax/">ProbeScript</a>
      <a href="/flutter-probe/tools/cli-reference/">CLI</a>
      <a href="https://github.com/AlphaWaveSystems/flutter-probe/wiki">Wiki</a>
      <a href="https://github.com/AlphaWaveSystems/flutter-probe">GitHub</a>
      <a href="/flutter-probe/getting-started/quick-start/" class="btn-sm">Quick Start</a>
    </div>
  </nav>
  <!-- Hero -->
  <div class="hero">
    <div class="badge"><span></span> v0.2.0 &mdash; BSL 1.1 open source</div>
    <h1>Flutter E2E tests in<br/><span class="g">plain English</span></h1>
    <p class="sub">Write tests your whole team can read. Execute with direct widget-tree access &mdash; no accessibility layer, no WebDriver overhead.</p>
    <div class="hero-code">
      <div class="bar"><div class="dot"></div><div class="dot"></div><div class="dot"></div><span class="fname">login.probe</span></div>
      <pre><span class="kw">test</span> <span class="str">"user can log in"</span>
  <span class="cmd">open the app</span>
  <span class="cmd">tap</span> <span class="str">"Sign In"</span>
  <span class="cmd">type</span> <span class="str">"user@test.com"</span> <span class="cmd">into</span> <span class="str">"Email"</span>
  <span class="cmd">type</span> <span class="str">"secret"</span> <span class="cmd">into</span> <span class="str">"Password"</span>
  <span class="cmd">tap</span> <span class="str">"Continue"</span>
  <span class="cmd">see</span> <span class="str">"Dashboard"</span>         <span class="cmt">{'<!-- 7 lines. Done. -->'}</span></pre>
    </div>
    <div class="cta">
      <a href="/flutter-probe/getting-started/installation/" class="btn-p">Get Started</a>
      <a href="/flutter-probe/getting-started/quick-start/" class="btn-s">Quick Start Guide</a>
    </div>
  </div>
  <!-- Metrics -->
  <div class="metrics">
    <div class="metric"><div class="num t">&lt;50ms</div><div class="lbl">Command round-trip</div></div>
    <div class="metric"><div class="num g">&lt;0.5%</div><div class="lbl">Flake rate</div></div>
    <div class="metric"><div class="num p">&lt;100ms</div><div class="lbl">CLI cold start</div></div>
    <div class="metric"><div class="num a">7</div><div class="lbl">Migration formats</div></div>
  </div>
  <div class="divider"></div>
  <!-- Architecture -->
  <section>
    <div class="sec-h"><h2>Architecture</h2><p>Two components. One WebSocket. Zero flakiness.</p></div>
    <div class="arch">
      <div class="arch-box">
        <h3>probe CLI</h3>
        <p>Parses .probe files, manages devices, dispatches commands, generates reports</p>
        <span class="tag tag-go">Go &middot; 15MB binary</span>
      </div>
      <div class="arch-arrow">
        <span style="font-size:2rem">&#8652;</span>
        <span class="arch-label">JSON-RPC 2.0</span>
        <span class="arch-label">WebSocket :48686</span>
      </div>
      <div class="arch-box">
        <h3>ProbeAgent</h3>
        <p>Runs inside your app. Walks widget tree, executes actions, captures screenshots</p>
        <span class="tag tag-dart">Dart &middot; dev dependency</span>
      </div>
    </div>
  </section>
  <div class="divider"></div>
  <!-- Features -->
  <section>
    <div class="sec-h"><h2>Everything you need</h2><p>No plugins to install. No extra packages. Batteries included.</p></div>
    <div class="features">
      <div class="feat"><h3><span class="ic ic-t">N</span> Natural language</h3><p>ProbeScript reads like English. No locators, no async/await. QA, product, and engineering can all read the tests.</p></div>
      <div class="feat"><h3><span class="ic ic-g">&#9889;</span> Sub-50ms execution</h3><p>Direct widget-tree access via the Dart agent. No XPath, no accessibility bridge. Command round-trips under 50 milliseconds.</p></div>
      <div class="feat"><h3><span class="ic ic-p">&#8635;</span> Watch mode</h3><p>Re-runs on file save with hot-reload awareness. Iteration cycles under 2 seconds. No recompilation needed.</p></div>
      <div class="feat"><h3><span class="ic ic-a">&#8853;</span> Cross-platform</h3><p>Same tests on Android emulators and iOS simulators. Permissions, lifecycle, and platform quirks handled automatically.</p></div>
      <div class="feat"><h3><span class="ic ic-c">&#9673;</span> Test recording</h3><p>Record taps, swipes, and text input on a real device. FlutterProbe writes the .probe file as you interact.</p></div>
      <div class="feat"><h3><span class="ic ic-t">&#9651;</span> Visual regression</h3><p>Screenshot baselines with configurable pixel thresholds. Catch unintended UI changes before they ship.</p></div>
      <div class="feat"><h3><span class="ic ic-g">&#11041;</span> HTTP mocking</h3><p>Mock API responses directly in test files. No external packages, no separate mock server.</p></div>
      <div class="feat"><h3><span class="ic ic-p">&#9044;</span> CI/CD ready</h3><p>JUnit XML, JSON, HTML reports. Official Docker image. GitHub Actions workflow included. Test sharding with --shard N.</p></div>
    </div>
  </section>
  <div class="divider"></div>
  <!-- Comparison -->
  <section>
    <div class="sec-h"><h2>Side by side</h2><p>Same login test. Different experience.</p></div>
    <div class="compare">
      <div class="compare-col">
        <div class="compare-hd"><span>FlutterProbe</span><span class="lines">7 lines</span></div>
        <div class="compare-code"><span style="color:#a78bfa">test</span> <span style="color:#3bea7e">"user can log in"</span>
  open the app
  tap <span style="color:#3bea7e">"Sign In"</span>
  type <span style="color:#3bea7e">"user@test.com"</span> into <span style="color:#3bea7e">"Email"</span>
  type <span style="color:#3bea7e">"secret"</span> into <span style="color:#3bea7e">"Password"</span>
  tap <span style="color:#3bea7e">"Continue"</span>
  see <span style="color:#3bea7e">"Dashboard"</span></div>
      </div>
      <div class="compare-col">
        <div class="compare-hd"><span>flutter_test</span><span class="lines">13 lines</span></div>
        <div class="compare-code"><span style="color:#a78bfa">testWidgets</span>(<span style="color:#3bea7e">'user can log in'</span>, (t) <span style="color:#a78bfa">async</span> {'{'}<br/>  app.main();<br/>  <span style="color:#a78bfa">await</span> t.pumpAndSettle();<br/>  <span style="color:#a78bfa">await</span> t.tap(find.text(<span style="color:#3bea7e">'Sign In'</span>));<br/>  <span style="color:#a78bfa">await</span> t.pumpAndSettle();<br/>  <span style="color:#a78bfa">await</span> t.enterText(<br/>    find.byType(TextField).first,<br/>    <span style="color:#3bea7e">'user@test.com'</span>);<br/>  <span style="color:#a78bfa">await</span> t.enterText(<br/>    find.byType(TextField).last,<br/>    <span style="color:#3bea7e">'secret'</span>);<br/>  <span style="color:#a78bfa">await</span> t.tap(find.text(<span style="color:#3bea7e">'Continue'</span>));<br/>  <span style="color:#a78bfa">await</span> t.pumpAndSettle();<br/>  expect(find.text(<span style="color:#3bea7e">'Dashboard'</span>),<br/>    findsOneWidget);<br/>{'}'});</div>
      </div>
    </div>
  </section>
  <div class="divider"></div>
  <!-- Migration -->
  <section>
