# Common recipes shared across all Digacel test suites

recipe "open and wait for the app"
  open the app
  wait 3 seconds
  see "Lector"

recipe "navigate to keypad"
  tap "Dígita"
  wait 2 seconds
  see "Digita el número de 10 dígitos"

recipe "go back to main menu"
  go back
  wait 1 seconds
  see "Lector"
