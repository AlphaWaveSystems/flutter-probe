# Smoke test: core navigation paths
use "tests/recipes/common.probe"

before each test
  open and wait for the app

after each test
  take a screenshot

on failure
  take a screenshot called "failure"
  dump the widget tree
  save device logs

test "main menu options are accessible"
  @smoke
  see "Lector"
  see "Dígita"
  see "número"

test "navigate to keypad and back"
  @smoke
  navigate to keypad
  see "Activar"
  go back to main menu

test "navigate to lector and back"
  @smoke
  tap "Lector"
  wait 2 seconds
  go back
  wait 1 seconds
  see "Lector"
  see "Dígita"
