# Code activation flow tests
use "tests/recipes/common.probe"

before each test
  open and wait for the app

after each test
  take a screenshot

on failure
  take a screenshot called "activation_failure"
  dump the widget tree

test "invalid code shows error dialog"
  navigate to keypad
  tap 2nd "1"
  wait 1 seconds
  tap 2nd "2"
  wait 1 seconds
  tap 2nd "3"
  wait 1 seconds
  tap 2nd "4"
  wait 1 seconds
  tap 2nd "5"
  wait 1 seconds
  tap "Activar"
  wait 2 seconds
  see "El código escaneado no tiene información válida"
  tap "Aceptar"
  wait 1 seconds
  see "Lector"

test "user can dismiss error and return to main menu"
  navigate to keypad
  tap 2nd "9"
  wait 1 seconds
  tap 2nd "9"
  wait 1 seconds
  tap 2nd "9"
  wait 1 seconds
  tap 2nd "9"
  wait 1 seconds
  tap 2nd "9"
  wait 1 seconds
  tap "Activar"
  wait 2 seconds
  see "Info."
  tap "Aceptar"
  wait 2 seconds
  see "Lector"
