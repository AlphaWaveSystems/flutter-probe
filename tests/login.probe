# Activation code entry tests
use "tests/recipes/common.probe"

before each test
  open and wait for the app

on failure
  take a screenshot called "activation_failure"
  dump the widget tree

test "user can enter a code and activate"
  @critical
  navigate to keypad
  tap 2nd "8"
  wait 1 seconds
  tap 2nd "8"
  wait 1 seconds
  tap 2nd "8"
  wait 1 seconds
  tap 2nd "0"
  wait 1 seconds
  tap 2nd "0"
  wait 1 seconds
  tap "Activar"
  wait 2 seconds
  see "El código escaneado no tiene información válida"
  tap "Aceptar"

test "keypad shows all digits"
  navigate to keypad
  see "1"
  see "2"
  see "3"
  see "4"
  see "5"
  see "6"
  see "7"
  see "9"
  see "0"

test "activar button is visible on keypad"
  navigate to keypad
  see "Activar"
  see "Digita el número de 10 dígitos"
