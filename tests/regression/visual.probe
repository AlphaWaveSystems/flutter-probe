# Visual regression test suite
# Each test captures a screenshot and compares against a baseline.
use "tests/recipes/common.probe"

before each test
  open and wait for the app

test "main menu visual regression"
  wait 1 seconds
  take a screenshot called "main_menu"

test "keypad visual regression"
  navigate to keypad
  wait 1 seconds
  take a screenshot called "keypad_screen"
