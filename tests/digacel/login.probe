# Digacel login tests — validates PR #40 (login UX improvements) and PR #38 (silent login)

on failure
  take a screenshot called "login_failure"
  dump the widget tree

# ---- Tests ----

test "happy path login reaches main menu"
  @smoke @critical
  open the app
  wait until "Login" appears
  type "test01" into "Usuario"
  type "123456" into "Contraseña"
  tap "Login"
  wait until "Lector" appears
  see "Dígita"
  take a screenshot called "login_success"

test "menu drawer shows user info and logout"
  @smoke
  tap #MenuButton
  wait 2 seconds
  see "Salir"
  see "Notificaciones"
  see "test01"
  take a screenshot called "menu_drawer"
  go back
  wait 1 seconds

test "login screen has required fields and labels"
  tap #MenuButton
  wait 2 seconds
  tap "Salir"
  wait 4 seconds
  see "Usuario"
  see "Contraseña"
  see "Login"
  see "aviso de privacidad"

test "wrong credentials show Spanish error"
  @critical
  type "wronguser" into "Usuario"
  type "wrongpass" into "Contraseña"
  tap "Login"
  wait 3 seconds
  see "Usuario no encontrado"
  take a screenshot called "wrong_credentials"

test "input sanitization strips whitespace and lowercases username"
  @critical
  # PR #40: _LowercaseTextFormatter + whitespace filter on email field
  # Still on login screen from previous test (wrong credentials)
  type "<username>" into "Usuario"
  type "123456" into "Contraseña"
  tap "Login"
  wait until "Lector" appears
  see "Dígita"
  take a screenshot called "sanitized_login"
  # Restart and logout for next permutation
  restart the app
  wait until "Lector" appears
  wait 2 seconds
  tap #MenuButton
  wait 2 seconds
  tap "Salir"
  wait 4 seconds

with examples:
  username
  " test01"
  "TEST01"
  " Test01 "
  "  TEST01  "

test "silent login after app restart"
  @critical
  # Log back in from current screen
  type "test01" into "Usuario"
  type "123456" into "Contraseña"
  tap "Login"
  wait until "Lector" appears
  # PR #38: FCM token no longer blocks silent login
  restart the app
  wait until "Lector" appears
  see "Dígita"
  don't see "Login"
  don't see "Usuario"
  take a screenshot called "silent_login"
