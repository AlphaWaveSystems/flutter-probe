# App launch and initial state tests

test "app shows main menu on launch"
  open the app
  wait 3 seconds
  see "Lector"
  see "Dígita"
  see "número"
  don't see "Error"

test "app recovers after navigating between screens"
  open the app
  wait 3 seconds
  tap "Dígita"
  wait 2 seconds
  see "Activar"
  go back
  wait 1 seconds
  tap "Lector"
  wait 2 seconds
  go back
  wait 1 seconds
  see "Lector"
  see "Dígita"
