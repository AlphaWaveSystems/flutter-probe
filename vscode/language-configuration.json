{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" },
    { "open": "<", "close": ">" }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" },
    { "open": "<", "close": ">" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(test|recipe|before each|after each|on failure|if|else|repeat|when|with examples|run dart)\\b",
    "decreaseIndentPattern": "^\\s*(else)\\b"
  },
  "folding": {
    "offSide": true
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
