{
  "name": "flutterprobe",
  "displayName": "FlutterProbe",
  "description": "High-performance E2E testing for Flutter apps — ProbeScript language support, local & cloud device testing (BrowserStack, Sauce Labs, AWS Device Farm, Firebase Test Lab, LambdaTest), visual regression, test recording, and Studio integration",
  "version": "0.4.1",
  "publisher": "flutterprobe",
  "icon": "resources/probe-icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Testing", "Languages", "Snippets"],
  "keywords": ["flutter", "testing", "e2e", "probe", "probescript", "mobile", "browserstack", "saucelabs", "device-farm", "firebase", "visual-regression", "cloud-testing"],
  "repository": {
    "type": "git",
    "url": "https://github.com/AlphaWaveSystems/flutter-probe"
  },
  "activationEvents": [
    "onLanguage:probescript",
    "workspaceContains:**/*.probe",
    "workspaceContains:probe.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "probescript",
        "aliases": ["ProbeScript", "probe"],
        "extensions": [".probe"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "probescript",
        "scopeName": "source.probe",
        "path": "./syntaxes/probe.tmGrammar.json"
      }
    ],
    "snippets": [
      {
        "language": "probescript",
        "path": "./snippets/probescript.json"
      }
    ],
    "commands": [
      {
        "command": "flutterprobe.runTest",
        "title": "FlutterProbe: Run Test at Cursor",
        "icon": "$(play)"
      },
      {
        "command": "flutterprobe.runFile",
        "title": "FlutterProbe: Run File",
        "icon": "$(run-all)"
      },
      {
        "command": "flutterprobe.runByTag",
        "title": "FlutterProbe: Run by Tag",
        "icon": "$(tag)"
      },
      {
        "command": "flutterprobe.runWithOptions",
        "title": "FlutterProbe: Run with Options..."
      },
      {
        "command": "flutterprobe.runProfile",
        "title": "FlutterProbe: Configure Run Options"
      },
      {
        "command": "flutterprobe.lintFile",
        "title": "FlutterProbe: Lint File"
      },
      {
        "command": "flutterprobe.lintWorkspace",
        "title": "FlutterProbe: Lint Workspace"
      },
      {
        "command": "flutterprobe.record",
        "title": "FlutterProbe: Start Recording",
        "icon": "$(record)"
      },
      {
        "command": "flutterprobe.stopRecord",
        "title": "FlutterProbe: Stop Recording",
        "icon": "$(debug-stop)"
      },
      {
        "command": "flutterprobe.listDevices",
        "title": "FlutterProbe: List Devices",
        "icon": "$(device-mobile)"
      },
      {
        "command": "flutterprobe.startDevice",
        "title": "FlutterProbe: Start Device/Emulator"
      },
      {
        "command": "flutterprobe.generateReport",
        "title": "FlutterProbe: Generate HTML Report"
      },
      {
        "command": "flutterprobe.openReport",
        "title": "FlutterProbe: Open Report"
      },
      {
        "command": "flutterprobe.openStudio",
        "title": "FlutterProbe: Open Studio",
        "icon": "$(inspect)"
      },
      {
        "command": "flutterprobe.init",
        "title": "FlutterProbe: Init Project"
      },
      {
        "command": "flutterprobe.convert",
        "title": "FlutterProbe: Convert Tests from Other Frameworks"
      },
      {
        "command": "flutterprobe.addSession",
        "title": "FlutterProbe: Add Session",
        "icon": "$(add)"
      },
      {
        "command": "flutterprobe.removeSession",
        "title": "FlutterProbe: Remove Session",
        "icon": "$(trash)"
      },
      {
        "command": "flutterprobe.editSession",
        "title": "FlutterProbe: Edit Session",
        "icon": "$(edit)"
      },
      {
        "command": "flutterprobe.runOnSession",
        "title": "FlutterProbe: Run All Tests on Session",
        "icon": "$(run-all)"
      },
      {
        "command": "flutterprobe.runFileOnSession",
        "title": "FlutterProbe: Run Current File on Session",
        "icon": "$(play)"
      },
      {
        "command": "flutterprobe.runOnAllSessions",
        "title": "FlutterProbe: Run on All Sessions (Parallel)",
        "icon": "$(run-all)"
      },
      {
        "command": "flutterprobe.refreshSessions",
        "title": "FlutterProbe: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "flutterprobe.refreshTests",
        "title": "FlutterProbe: Refresh Test Explorer",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutterprobe",
          "title": "FlutterProbe",
          "icon": "resources/probe-icon.svg"
        }
      ]
    },
    "views": {
      "flutterprobe": [
        {
          "id": "flutterprobe.sessions",
          "name": "Sessions"
        },
        {
          "id": "flutterprobe.tests",
          "name": "Tests"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .probe",
          "command": "flutterprobe.runFile",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .probe",
          "command": "flutterprobe.runTest",
          "group": "flutterprobe@1"
        },
        {
          "when": "resourceExtname == .probe",
          "command": "flutterprobe.runFile",
          "group": "flutterprobe@2"
        },
        {
          "when": "resourceExtname == .probe",
          "command": "flutterprobe.lintFile",
          "group": "flutterprobe@3"
        }
      ],
      "view/title": [
        {
          "command": "flutterprobe.addSession",
          "when": "view == flutterprobe.sessions",
          "group": "navigation"
        },
        {
          "command": "flutterprobe.runOnAllSessions",
          "when": "view == flutterprobe.sessions",
          "group": "navigation"
        },
        {
          "command": "flutterprobe.refreshSessions",
          "when": "view == flutterprobe.sessions",
          "group": "navigation"
        },
        {
          "command": "flutterprobe.refreshTests",
          "when": "view == flutterprobe.tests",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "flutterprobe.runOnSession",
          "when": "viewItem == session",
          "group": "inline"
        },
        {
          "command": "flutterprobe.runFileOnSession",
          "when": "viewItem == session",
          "group": "inline"
        },
        {
          "command": "flutterprobe.editSession",
          "when": "viewItem == session"
        },
        {
          "command": "flutterprobe.removeSession",
          "when": "viewItem == session"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "command": "flutterprobe.runTest",
        "when": "editorLangId == probescript"
      },
      {
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "command": "flutterprobe.runFile",
        "when": "editorLangId == probescript"
      },
      {
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "command": "flutterprobe.lintFile",
        "when": "editorLangId == probescript"
      },
      {
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "command": "flutterprobe.runOnAllSessions",
        "when": "editorLangId == probescript"
      }
    ],
    "configuration": {
      "title": "FlutterProbe",
      "properties": {
        "flutterprobe.probePath": {
          "type": "string",
          "default": "probe",
          "description": "Path to the probe CLI binary"
        },
        "flutterprobe.autoLint": {
          "type": "boolean",
          "default": true,
          "description": "Lint .probe files on save"
        },
        "flutterprobe.studioPort": {
          "type": "number",
          "default": 9191,
          "description": "Port for probe studio"
        },
        "flutterprobe.defaultDevice": {
          "type": "string",
          "default": "",
          "description": "Default device serial for running tests"
        },
        "flutterprobe.defaultTimeout": {
          "type": "string",
          "default": "30s",
          "description": "Default per-step timeout"
        },
        "flutterprobe.autoConfirm": {
          "type": "boolean",
          "default": false,
          "description": "Auto-confirm destructive actions (-y flag)"
        },
        "flutterprobe.outputFormat": {
          "type": "string",
          "default": "terminal",
          "enum": ["terminal", "junit", "json"],
          "description": "Default output format for test results"
        },
        "flutterprobe.outputPath": {
          "type": "string",
          "default": "",
          "description": "Default output file path for test results"
        },
        "flutterprobe.video": {
          "type": "boolean",
          "default": false,
          "description": "Record video during test runs"
        },
        "flutterprobe.videoResolution": {
          "type": "string",
          "default": "720x1280",
          "description": "Video recording resolution"
        },
        "flutterprobe.videoFramerate": {
          "type": "number",
          "default": 2,
          "description": "Video recording framerate (fps)"
        },
        "flutterprobe.visualThreshold": {
          "type": "number",
          "default": 0.5,
          "description": "Visual regression threshold (%)"
        },
        "flutterprobe.visualPixelDelta": {
          "type": "number",
          "default": 8,
          "description": "Visual regression per-pixel delta tolerance"
        },
        "flutterprobe.agentPort": {
          "type": "number",
          "default": 48686,
          "description": "Agent WebSocket host port"
        },
        "flutterprobe.dialTimeout": {
          "type": "string",
          "default": "30s",
          "description": "WebSocket dial timeout"
        },
        "flutterprobe.tokenTimeout": {
          "type": "string",
          "default": "30s",
          "description": "Agent token wait timeout"
        },
        "flutterprobe.reconnectDelay": {
          "type": "string",
          "default": "2s",
          "description": "Post-restart reconnect delay"
        },
        "flutterprobe.adbPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to adb binary"
        },
        "flutterprobe.flutterPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to flutter binary"
        },
        "flutterprobe.convertPath": {
          "type": "string",
          "default": "probe-convert",
          "description": "Path to the probe-convert binary"
        },
        "flutterprobe.cloudProvider": {
          "type": "string",
          "default": "",
          "enum": ["", "browserstack", "saucelabs", "lambdatest", "aws", "firebase"],
          "enumDescriptions": [
            "None (local testing)",
            "BrowserStack App Automate",
            "Sauce Labs Real Device Cloud",
            "LambdaTest Real Devices",
            "AWS Device Farm",
            "Firebase Test Lab"
          ],
          "description": "Cloud device farm provider for remote testing"
        },
        "flutterprobe.cloudDevice": {
          "type": "string",
          "default": "",
          "description": "Cloud device string (e.g., \"Google Pixel 7-13.0\", \"iPhone 14-16.0\")"
        },
        "flutterprobe.cloudApp": {
          "type": "string",
          "default": "",
          "description": "Path to app binary (.apk or .ipa) for cloud testing"
        },
        "flutterprobe.cloudKey": {
          "type": "string",
          "default": "",
          "description": "Cloud provider username or access key ID"
        },
        "flutterprobe.cloudSecret": {
          "type": "string",
          "default": "",
          "description": "Cloud provider access key or secret (stored in settings — consider using env vars for CI)"
        },
        "flutterprobe.relayUrl": {
          "type": "string",
          "default": "",
          "description": "Relay server URL for cloud E2E testing (required for Firebase Test Lab and relay-mode cloud providers)"
        },
        "flutterprobe.relayToken": {
          "type": "string",
          "default": "",
          "description": "Relay authentication token"
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "flutterprobe",
        "properties": {
          "file": { "type": "string" },
          "tag": { "type": "string" }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
